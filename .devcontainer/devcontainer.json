{
  "name": "claude-code-2.1.88",

  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },

  "remoteUser": "node",
  "updateRemoteUserUID": true,

  "workspaceMount": "source=claude-code-src,target=/workspaces/claude-code-2_1_88,type=volume",
  "workspaceFolder": "/workspaces/claude-code-2_1_88",

  "features": {
    "ghcr.io/zkaiwen5810/features/ai-coding-cli:latest": {
      "nodeMajor": "20",
      "installZsh": true,
      "installZshrc": true
    }
  },

  "runArgs": [
    "--env-file",
    "${localWorkspaceFolder}/.devcontainer.env"
  ],

  "mounts": [
    "source=pnpm-store,target=/home/node/.pnpm-store,type=volume",

    "source=codex-home,target=/home/node/.codex,type=volume",

    "source=claude-home,target=/home/node/.claude,type=volume",
    "source=claude-config,target=/home/node/.config/claude,type=volume",
    "source=claude-cache,target=/home/node/.cache/claude,type=volume",

    "source=opencode-config,target=/home/node/.config/opencode,type=volume",
    "source=opencode-share,target=/home/node/.local/share/opencode,type=volume",

    "source=claude-code-persist,target=/home/node/.persist,type=volume"
  ],

  "containerEnv": {
    "PNPM_STORE_DIR": "/home/node/.pnpm-store",
    "SHELL": "/usr/bin/zsh"
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh"
}